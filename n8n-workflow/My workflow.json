      ],
      "id": "bfe2e68d-3a69-4245-b02f-70382bb3358d",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  // Get a list of all column headers in this row\n  const allColumns = Object.keys(item.json);\n  \n  // If there is at least one column...\n  if (allColumns.length > 0) {\n    // Grab the name of the very first column (whatever it is!)\n    const firstColumnName = allColumns[0];\n    \n    // Create a new standard field called 'reviews' and copy the data into it\n    item.json.reviews = item.json[firstColumnName];\n  }\n}\nreturn $input.all();"
      },
