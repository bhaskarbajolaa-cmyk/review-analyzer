      ],
      "id": "cc62fc73-1c75-4a54-abd5-e55bbd6d2ba3",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  // Check if the text field exists from your React app\n  if (item.json.text) {\n    // This finds all physical line breaks and safely replaces them with \\n\n    item.json.Text = item.json.text.replace(/\\r?\\n|\\r/g, '\\\\n');\n  }\n}\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
