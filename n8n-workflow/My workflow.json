    {
      "parameters": {
        "jsCode": "// Each item has a .json property\nconst results = [];\n\nfor (const item of items) {\n  const raw = item.json.choices?.[0]?.message?.content || \"{}\";\n  try {\n    const parsed = JSON.parse(raw);\n    results.push({ json: parsed });\n  } catch (e) {\n    results.push({\n      json: {\n        entities: [],\n        sentiment: { positive: 0, neutral: 0, negative: 0 },\n        pros: [],\n        cons: [],\n        readability_score: 0,\n        style: \"\",\n        summary: \"\"\n      }\n    });\n  }\n}\n\nreturn results;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
