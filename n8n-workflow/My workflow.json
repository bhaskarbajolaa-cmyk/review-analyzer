        "functionCode": "const raw = $json.choices?.[0]?.message?.content || \"\";\n// Remove code fences like ```json ... ```\nconst cleaned = raw.replace(/```json|```/g, \"\").trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  // Fallback structure if parsing fails\n  parsed = {\n    sentiment: {\n      positive: 0,\n      neutral: 0,\n      negative: 0\n    },\n    pros: [],\n    cons: [],\n    summary: \"\"\n  };\n}\n\n// Return parsed JSON only\nreturn [\n  {\n    json: parsed\n  }\n];\n"
      },
